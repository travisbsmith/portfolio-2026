---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import DashboardNav from '../../components/DashboardNav.astro';
import { getLeads } from '../../lib/leads';
import Stripe from 'stripe';

// Auth
const SESSION_COOKIE = 'dashboard_session';
if (Astro.cookies.get(SESSION_COOKIE)?.value !== 'authenticated') {
  return Astro.redirect('/dashboard');
}

// Load lead
const { id } = Astro.params;
const leads = await getLeads();
const lead = leads.find(l => l.id === id);
if (!lead) return Astro.redirect('/dashboard');

// Load Stripe invoices
let invoices: any[] = [];
if (lead.stripeCustomerId) {
  try {
    const stripe = new Stripe(import.meta.env.STRIPE_SECRET_KEY ?? process.env.STRIPE_SECRET_KEY ?? '');
    const result = await stripe.invoices.list({ customer: lead.stripeCustomerId, limit: 10 });
    invoices = result.data;
  } catch { /* Stripe not configured */ }
}

// Find latest open invoice URL for follow-up pre-fill
const latestOpenInvoice = invoices.find(inv => inv.status === 'open');
---

<BaseLayout title={`${lead.name} — Dashboard`} description="Lead detail">
<div class="lead-page">

  <DashboardNav active="clients" />

  <!-- ── Header ── -->
  <header class="lead-header">
    <div class="container">
      <div class="lead-header__inner">
        <div class="lead-header__left">
          <div class="lead-header__title">
            <h1>{lead.name}</h1>
            <a href={`mailto:${lead.email}`} class="lead-email">{lead.email}</a>
            {lead.storeUrl && (
              <a href={lead.storeUrl} target="_blank" rel="noopener" class="lead-store">
                {lead.storeUrl.replace(/^https?:\/\//, '')} ↗
              </a>
            )}
          </div>
        </div>
        <div class="lead-header__right">
          <span class="header-label">Stage</span>
          <select id="stage-select" class="stage-select" data-lead-id={lead.id} data-current={lead.stage}>
            {['Lead','Call Scheduled','Proposal Sent','Active','Closed'].map(s => (
              <option value={s} selected={s === lead.stage}>{s}</option>
            ))}
          </select>
          <span id="stage-status" class="save-status"></span>
        </div>
      </div>
    </div>
  </header>

  <!-- ── Body ── -->
  <div class="lead-body container">
    <div class="lead-main">

      <!-- 1. Intake Details -->
      <section class="card">
        <div class="card__header"><h2>Intake Form</h2></div>
        <div class="card__body intake-grid">
          {[
            ['Store URL', lead.storeUrl],
            ['Store Status', lead.storeStatus],
            ['Launch Date', lead.launchDate],
            ['Visual Designer', lead.hasVisualDesigner],
            ['Interested In', lead.serviceInterest],
            ['Availability', lead.availability],
            ['Timezone', lead.timezone],
            ['Referral', lead.referral],
          ].map(([label, value]) => value ? (
            <div class="intake-row">
              <span class="intake-label">{label}</span>
              <span class="intake-value">{value}</span>
            </div>
          ) : null)}
          {lead.challenge && (
            <div class="intake-row intake-row--full">
              <span class="intake-label">Their Challenge</span>
              <span class="intake-value intake-value--long">{lead.challenge}</span>
            </div>
          )}
          {lead.additionalNotes && (
            <div class="intake-row intake-row--full">
              <span class="intake-label">Their Notes</span>
              <span class="intake-value intake-value--long">{lead.additionalNotes}</span>
            </div>
          )}
        </div>
      </section>

      <!-- 2. Discovery Call Guide -->
      <section class="card" id="call-guide-card">
        <button class="card__toggle" id="guide-toggle" aria-expanded="false">
          <span class="card__toggle-label">
            <span class="guide-icon">📋</span> Discovery Call Guide
          </span>
          <span class="card__toggle-arrow">▸</span>
        </button>
        <div class="card__body guide-body" id="guide-body" hidden>

          <div class="guide-section">
            <h3>Opening</h3>
            <blockquote>"Thanks for making time. This is a no-pitch call — I just want to understand what you're building and whether I can help. I'll take some notes as we go. Sound good?"</blockquote>
          </div>

          <div class="guide-section">
            <h3>Section 1 — Their Store <span class="guide-time">8 min</span></h3>
            <ul>
              <li>Is the store live, or are you still building it?</li>
              <li>What do you sell? Who's the customer?</li>
              <li>How long have you been on Shopify?</li>
            </ul>
            <p class="guide-if"><strong>If live:</strong> Getting traffic? Sales? AOV? Apps running?</p>
            <p class="guide-if"><strong>If not live:</strong> What's blocking the launch? Theme picked? Products ready? Deadline?</p>
          </div>

          <div class="guide-section">
            <h3>Section 2 — The Real Problem <span class="guide-time">8 min</span></h3>
            <ul>
              <li><strong>What's the #1 thing keeping you up at night about the store?</strong> <em>(Let them talk. Don't interrupt.)</em></li>
              <li>How long has that been the case?</li>
              <li>What have you tried so far?</li>
              <li>What happens if you don't solve this in the next 90 days?</li>
              <li>What does success look like in 6 months?</li>
              <li>Who else is involved in the store?</li>
            </ul>
          </div>

          <div class="guide-section">
            <h3>Section 3 — Fit Check <span class="guide-time">5 min</span></h3>
            <ul>
              <li>Worked with a Shopify consultant or agency before?</li>
              <li>What's your rough monthly budget for getting help?</li>
            </ul>
            <div class="budget-signals">
              <div class="signal">"Can't afford an agency" → <strong>Clarity Session $500</strong></div>
              <div class="signal">"Want ongoing support" → <strong>Insider Retainer $3,500/mo</strong></div>
              <div class="signal">"Need to launch fast" → <strong>Store Launch Sprint $2,500</strong></div>
              <div class="signal">"Just need focus" → <strong>Clarity Session $500</strong></div>
            </div>
          </div>

          <div class="guide-section">
            <h3>Section 4 — Your Background <span class="guide-time">3 min</span></h3>
            <blockquote>"I spent five years as Head of Design at Shopify, leading the teams that built Shopify Email, Inbox, Forms, and the Analytics and Customer sections of Admin. I know the platform from the inside."</blockquote>
          </div>

          <div class="guide-section">
            <h3>Closing <span class="guide-time">4 min</span></h3>
            <blockquote>"So it sounds like the main thing you're working on is [X], and the goal is [Y]. Is that right?"</blockquote>
            <blockquote>"Based on what you've told me, I think [SERVICE] makes the most sense. I'll send you a short proposal this afternoon — just what's included, what it costs, and how to get started."</blockquote>
          </div>

          <div class="guide-section guide-section--tree">
            <h3>Decision Tree</h3>
            <div class="decision-tree">
              <div class="tree-branch">Store not live → <strong>Store Launch Sprint $2,500</strong></div>
              <div class="tree-branch">Live, needs audit → <strong>Clarity Session $500</strong> → offer Retainer after</div>
              <div class="tree-branch">Live, wants ongoing → <strong>Insider Retainer $3,500/mo</strong></div>
              <div class="tree-branch">Unsure / testing → <strong>Clarity Session $500</strong> (lowest barrier)</div>
            </div>
          </div>

        </div>
      </section>

      <!-- 3. Notes -->
      <section class="card">
        <div class="card__header">
          <h2>Your Notes</h2>
          <span id="notes-status" class="save-status"></span>
        </div>
        <div class="card__body">
          <textarea
            id="notes-textarea"
            class="notes-textarea"
            placeholder="Notes from the call — what they said, key problems, budget signals, next steps..."
            data-lead-id={lead.id}
          >{lead.internalNotes}</textarea>
        </div>
      </section>

    </div>

    <!-- ── Sidebar ── -->
    <aside class="lead-sidebar">

      <!-- Actions -->
      <section class="card">
        <div class="card__header"><h2>Actions</h2></div>
        <div class="card__body">
          <div class="sidebar-actions">
            <button class="action-btn action-btn--accent" id="btn-proposal">Send Proposal</button>
            <button class="action-btn" id="btn-invoice">Send Invoice</button>
            <button class="action-btn" id="btn-followup">Send Follow-up</button>
          </div>
        </div>

        <!-- Invoice form panel -->
        <div class="action-panel" id="panel-invoice" hidden>
          <form id="invoice-form">
            <div class="form-row">
              <label>Service</label>
              <select name="service" id="inv-service">
                <option value="Clarity Session">Clarity Session</option>
                <option value="Store Launch Sprint">Store Launch Sprint</option>
                <option value="Insider Retainer">Insider Retainer</option>
                <option value="Custom">Custom</option>
              </select>
            </div>
            <div class="form-row">
              <label>Amount (USD)</label>
              <input type="number" name="amount" id="inv-amount" min="1" step="0.01" placeholder="500" />
            </div>
            <div class="form-row">
              <label>Description</label>
              <textarea name="description" id="inv-desc" rows="2" placeholder="90-min store audit + written action plan"></textarea>
            </div>
            <div id="invoice-feedback" class="form-feedback"></div>
            <div class="panel-actions">
              <button type="button" class="btn-cancel" data-panel="invoice">Cancel</button>
              <button type="submit" class="btn-send">Send Invoice</button>
            </div>
          </form>
        </div>

        <!-- Proposal form panel -->
        <div class="action-panel" id="panel-proposal" hidden>
          <form id="proposal-form">
            <div class="form-row">
              <label>To</label>
              <input type="email" name="to" value={lead.email} readonly />
            </div>
            <div class="form-row">
              <label>Subject</label>
              <input type="text" name="subject" id="prop-subject" value={`Proposal: ${lead.name} × Fully Operational`} />
            </div>
            <div class="form-row">
              <label>Body</label>
              <textarea name="body" id="prop-body" rows="14"></textarea>
            </div>
            <div id="proposal-feedback" class="form-feedback"></div>
            <div class="panel-actions">
              <button type="button" class="btn-cancel" data-panel="proposal">Cancel</button>
              <button type="submit" class="btn-send btn-send--accent">Send Proposal</button>
            </div>
          </form>
        </div>

        <!-- Follow-up form panel -->
        <div class="action-panel" id="panel-followup" hidden>
          <form id="followup-form">
            <div class="form-row">
              <label>To</label>
              <input type="email" name="to" value={lead.email} readonly />
            </div>
            <div class="form-row">
              <label>Subject</label>
              <input type="text" name="subject" id="fu-subject" value="Quick note from Travis" />
            </div>
            <div class="form-row">
              <label>Body</label>
              <textarea name="body" id="fu-body" rows="8"></textarea>
            </div>
            <div id="followup-feedback" class="form-feedback"></div>
            <div class="panel-actions">
              <button type="button" class="btn-cancel" data-panel="followup">Cancel</button>
              <button type="submit" class="btn-send">Send Email</button>
            </div>
          </form>
        </div>
      </section>

      <!-- Invoice History -->
      <section class="card">
        <div class="card__header"><h2>Invoices</h2></div>
        <div class="card__body">
          {invoices.length === 0 ? (
            <p class="empty">No invoices yet</p>
          ) : (
            <div class="invoice-list">
              {invoices.map((inv: any) => (
                <div class="invoice-row">
                  <div class="invoice-row__info">
                    {inv.hosted_invoice_url ? (
                      <a href={inv.hosted_invoice_url} target="_blank" rel="noopener" class="invoice-num">
                        {inv.number ?? inv.id.slice(-8)}
                      </a>
                    ) : (
                      <span class="invoice-num">{inv.number ?? inv.id.slice(-8)}</span>
                    )}
                    <span class="invoice-date">{new Date(inv.created * 1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                  <div class="invoice-row__meta">
                    <span class={`inv-status inv-status--${inv.status}`}>{inv.status}</span>
                    <span class="invoice-amount">${((inv.amount_due ?? 0) / 100).toFixed(2)}</span>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </section>

      <!-- Stripe Customer ID -->
      <section class="card">
        <div class="card__header"><h2>Stripe</h2></div>
        <div class="card__body">
          <div class="form-row">
            <label>Customer ID</label>
            <div class="stripe-id-row">
              <input type="text" id="stripe-customer-id" value={lead.stripeCustomerId} placeholder="cus_..." data-lead-id={lead.id} />
              <button id="stripe-id-save" class="btn-save">Save</button>
            </div>
            <span id="stripe-id-status" class="save-status"></span>
          </div>
        </div>
      </section>

    </aside>
  </div>
</div>
</BaseLayout>

<style>
  .lead-page {
    min-height: 100vh;
    background: var(--color-bg-alt);
  }

  /* ── Header ── */
  .lead-header {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .lead-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .lead-header__left {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    min-width: 0;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-accent); }

  .lead-header__title {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    min-width: 0;
  }

  .lead-header__title h1 {
    font-size: var(--text-xl);
    margin: 0;
    white-space: nowrap;
  }

  .lead-email {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .lead-email:hover { color: var(--color-text-secondary); }

  .lead-store {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    opacity: 0.8;
  }

  .lead-store:hover { opacity: 1; }

  .lead-header__right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .header-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
  }

  .stage-select {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: border-color 0.15s;
  }

  .stage-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .save-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    min-width: 60px;
    transition: opacity 0.3s;
  }

  .save-status.saving { color: var(--color-text-tertiary); }
  .save-status.saved  { color: #38a169; }
  .save-status.error  { color: #e53e3e; }

  /* ── Body layout ── */
  .lead-body {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-8);
    padding: var(--space-8) 0;
    align-items: start;
  }

  @media (max-width: 960px) {
    .lead-body { grid-template-columns: 1fr; }
  }

  /* ── Cards ── */
  .card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-6);
    overflow: hidden;
  }

  .card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .card__header h2 {
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .card__body {
    padding: var(--space-6);
  }

  /* ── Call Guide ── */
  .card__toggle {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: background 0.15s;
  }

  .card__toggle:hover { background: var(--color-bg-alt); }

  .card__toggle-label {
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .card__toggle-arrow {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    transition: transform 0.2s;
  }

  .card__toggle[aria-expanded="true"] .card__toggle-arrow {
    transform: rotate(90deg);
  }

  .guide-body {
    padding: var(--space-6);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .guide-section {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .guide-section:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .guide-section h3 {
    font-size: var(--text-xs);
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    margin: 0 0 var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .guide-time {
    font-weight: 400;
    color: var(--color-border-strong);
    background: var(--color-bg-alt);
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
  }

  .guide-section ul {
    padding-left: var(--space-4);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .guide-section ul li {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.55;
  }

  .guide-section blockquote {
    margin: var(--space-3) 0 0;
    padding: var(--space-4) var(--space-6);
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-alt);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .guide-section blockquote + blockquote {
    margin-top: var(--space-3);
  }

  .guide-if {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: var(--space-3) 0 0;
    line-height: 1.5;
  }

  .budget-signals {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .signal {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .signal strong { color: var(--color-accent); }

  .decision-tree {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .tree-branch {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .tree-branch strong { color: var(--color-text); }

  /* ── Notes ── */
  .notes-textarea {
    width: 100%;
    min-height: 240px;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    line-height: 1.65;
    resize: vertical;
    background: var(--color-bg);
    color: var(--color-text);
    box-sizing: border-box;
    transition: border-color 0.15s;
  }

  .notes-textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  /* ── Intake ── */
  .intake-grid {
    display: flex;
    flex-direction: column;
  }

  .intake-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .intake-row:first-child { padding-top: 0; }
  .intake-row:last-child { border-bottom: none; padding-bottom: 0; }

  .intake-row--full {
    grid-template-columns: 140px 1fr;
  }

  .intake-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    padding-top: 2px;
    line-height: 1.4;
  }

  .intake-value {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.55;
  }

  .intake-value--long {
    white-space: pre-wrap;
  }

  /* ── Sidebar ── */
  .lead-sidebar .card { margin-bottom: var(--space-4); }

  /* Action buttons */
  .sidebar-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .action-btn {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    text-align: left;
    transition: all 0.15s;
    color: var(--color-text);
  }

  .action-btn:hover {
    background: var(--color-bg);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .action-btn--accent {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .action-btn--accent:hover {
    background: var(--color-accent-hover);
    color: #fff;
    border-color: var(--color-accent-hover);
  }

  /* Action panels */
  .action-panel {
    padding: var(--space-6);
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-alt);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-4);
  }

  .form-row:last-of-type { margin-bottom: 0; }

  .form-row label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
  }

  .form-row input,
  .form-row select,
  .form-row textarea {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-row input[readonly] {
    opacity: 0.5;
    cursor: default;
  }

  .form-row textarea { resize: vertical; }

  .panel-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .btn-cancel {
    padding: var(--space-2) var(--space-3);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn-cancel:hover {
    border-color: var(--color-text-secondary);
    color: var(--color-text);
  }

  .btn-send {
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn-send:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-send--accent {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-send--accent:hover { background: var(--color-accent-hover); border-color: var(--color-accent-hover); }

  .form-feedback {
    font-size: var(--text-xs);
    min-height: 1.2em;
    font-family: var(--font-mono);
    margin-top: var(--space-3);
  }

  .form-feedback.success { color: #38a169; }
  .form-feedback.error   { color: #e53e3e; }

  /* ── Invoice list ── */
  .invoice-list {
    display: flex;
    flex-direction: column;
  }

  .invoice-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .invoice-row:first-child { padding-top: 0; }
  .invoice-row:last-child { border-bottom: none; padding-bottom: 0; }

  .invoice-row__info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .invoice-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: 500;
  }

  a.invoice-num:hover { text-decoration: underline; }

  .invoice-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .invoice-row__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
  }

  .inv-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .inv-status--paid   { color: #38a169; }
  .inv-status--open   { color: #d69e2e; }
  .inv-status--draft  { color: var(--color-text-tertiary); }
  .inv-status--void   { color: #e53e3e; }

  .invoice-amount {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  /* ── Stripe ID row ── */
  .stripe-id-row {
    display: flex;
    gap: var(--space-2);
  }

  .stripe-id-row input { flex: 1; }

  .btn-save {
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-xs);
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    color: var(--color-text-secondary);
    transition: all 0.15s;
  }

  .btn-save:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .empty {
    color: var(--color-text-tertiary);
    font-style: italic;
    font-size: var(--text-sm);
    margin: 0;
  }
</style>

<script define:vars={{
  leadId: lead.id,
  leadEmail: lead.email,
  leadName: lead.name,
  serviceInterest: lead.serviceInterest,
  latestOpenInvoiceUrl: latestOpenInvoice?.hosted_invoice_url ?? '',
}}>

// ── Proposal templates ──
const PROPOSAL_TEMPLATES = {
  'Clarity Session': {
    price: '$500',
    block: `- 90-minute deep-dive on your store via video call\n- I'll review your UX, app stack, marketing setup, and biggest growth blockers\n- Written action plan with your top 3–5 priorities delivered within 48 hours\n\nTo book: Pay here → [Stripe link] and I'll send a calendar invite`,
  },
  'Store Launch Sprint': {
    price: '$2,500/month',
    block: `**Month 1 — Foundation**\n- Store architecture: product data model, metafields, collections, navigation\n- Consumer education pages + ingredient/product index (the content that converts before you have reviews)\n- Email waitlist setup — pre-launch page + Klaviyo or Shopify Email so you're building the list now\n- App stack map: exactly which apps you need, which to skip, zero vendor lock-in\n\n**Ongoing**\n- 10–15 hours/month\n- Email access for questions between sessions\n- Monthly check-in on priorities\n\n**Investment:** $2,500/month — Month 1 is on me while we establish the engagement.\n\nTo get started: Reply here and I'll send a kickoff doc with what I need from you to begin.`,
  },
  'Insider Retainer': {
    price: '$3,500/month',
    block: `- 2 × 30-min strategy calls per month\n- Async access Mon–Fri (email), 24-hr response\n- Monthly written audit: top 3 priorities + recommendations\n- Up to 5 hrs/month of hands-on work\n- Month-to-month, cancel anytime\n\nTo get started: Pay the first month here → [Stripe link] and I'll send an onboarding doc`,
  },
};

// ── Call guide toggle ──
const guideToggle = document.getElementById('guide-toggle');
const guideBody = document.getElementById('guide-body');
const savedGuideState = localStorage.getItem('guide-open-' + leadId);

if (savedGuideState === 'true') {
  guideToggle.setAttribute('aria-expanded', 'true');
  guideBody.hidden = false;
}

guideToggle.addEventListener('click', () => {
  const isOpen = guideToggle.getAttribute('aria-expanded') === 'true';
  guideToggle.setAttribute('aria-expanded', String(!isOpen));
  guideBody.hidden = isOpen;
  localStorage.setItem('guide-open-' + leadId, String(!isOpen));
});

// ── Stage auto-save ──
const stageSelect = document.getElementById('stage-select');
const stageStatus = document.getElementById('stage-status');

stageSelect.addEventListener('change', async () => {
  stageStatus.textContent = 'Saving...';
  stageStatus.className = 'save-status saving';
  try {
    const res = await fetch(`/api/leads/${leadId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ stage: stageSelect.value }),
    });
    if (res.ok) {
      stageStatus.textContent = 'Saved ✓';
      stageStatus.className = 'save-status saved';
      setTimeout(() => { stageStatus.textContent = ''; }, 2000);
    } else {
      stageStatus.textContent = 'Error';
      stageStatus.className = 'save-status error';
    }
  } catch {
    stageStatus.textContent = 'Error';
    stageStatus.className = 'save-status error';
  }
});

// ── Notes auto-save ──
const notesTextarea = document.getElementById('notes-textarea');
const notesStatus = document.getElementById('notes-status');
let notesTimer = null;

notesTextarea.addEventListener('input', () => {
  notesStatus.textContent = '';
  clearTimeout(notesTimer);
  notesTimer = setTimeout(async () => {
    notesStatus.textContent = 'Saving...';
    notesStatus.className = 'save-status saving';
    try {
      const res = await fetch(`/api/leads/${leadId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ internalNotes: notesTextarea.value }),
      });
      if (res.ok) {
        notesStatus.textContent = 'Saved ✓';
        notesStatus.className = 'save-status saved';
        setTimeout(() => { notesStatus.textContent = ''; }, 2000);
      } else {
        notesStatus.textContent = 'Error saving';
        notesStatus.className = 'save-status error';
      }
    } catch {
      notesStatus.textContent = 'Error saving';
      notesStatus.className = 'save-status error';
    }
  }, 800);
});

// ── Action panel toggles ──
function openPanel(name) {
  ['invoice','proposal','followup'].forEach(p => {
    document.getElementById('panel-' + p).hidden = p !== name;
  });
}

document.getElementById('btn-invoice').addEventListener('click', () => {
  // Pre-fill service from serviceInterest
  const serviceMap = { 'Clarity Session': 'Clarity Session', 'Store Launch Sprint': 'Store Launch Sprint', 'Insider Retainer': 'Insider Retainer' };
  const serviceEl = document.getElementById('inv-service');
  for (const opt of serviceEl.options) {
    if (serviceInterest && serviceInterest.includes(opt.value)) { opt.selected = true; break; }
  }
  // Pre-fill amount
  const amountMap = { 'Clarity Session': '500', 'Store Launch Sprint': '2500', 'Insider Retainer': '3500' };
  const amountEl = document.getElementById('inv-amount');
  for (const [key, val] of Object.entries(amountMap)) {
    if (serviceInterest && serviceInterest.includes(key)) { amountEl.value = val; break; }
  }
  openPanel('invoice');
});

document.getElementById('btn-proposal').addEventListener('click', () => {
  // Find matching template
  let template = null;
  for (const [key, tpl] of Object.entries(PROPOSAL_TEMPLATES)) {
    if (serviceInterest && serviceInterest.includes(key)) { template = { key, ...tpl }; break; }
  }
  const firstName = leadName.split(' ')[0];
  const body = template
    ? `Hi ${firstName},\n\nGreat talking today. Here's what I'd suggest based on our conversation.\n\n---\n\n**${template.key || 'Service'}**\n[One sentence on why this is the right fit — reference something they said on the call.]\n\n**What's included:**\n${template.block}\n\n**Investment:** ${template.price}\n\nQuestions? Just reply here.\n\n— Travis\ntravis@fully-operational.com`
    : `Hi ${firstName},\n\nGreat talking today. Here's what I'd suggest based on our conversation.\n\n---\n\n[SERVICE + details]\n\n**Investment:** [PRICE]\n\nQuestions? Just reply here.\n\n— Travis\ntravis@fully-operational.com`;
  document.getElementById('prop-body').value = body;
  openPanel('proposal');
});

document.getElementById('btn-followup').addEventListener('click', () => {
  const firstName = leadName.split(' ')[0];
  const body = latestOpenInvoiceUrl
    ? `Hi ${firstName},\n\nJust a quick check-in — your invoice is still open.\n\nView and pay here: ${latestOpenInvoiceUrl}\n\nLet me know if you have any questions.\n\n— Travis`
    : `Hi ${firstName},\n\nJust following up on our conversation — happy to answer any questions or chat more about next steps.\n\n— Travis`;
  document.getElementById('fu-body').value = body;
  openPanel('followup');
});

document.querySelectorAll('.btn-cancel').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('panel-' + btn.dataset.panel).hidden = true;
  });
});

// ── Invoice form ──
document.getElementById('invoice-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('.btn-send');
  const feedback = document.getElementById('invoice-feedback');
  btn.disabled = true; btn.textContent = 'Sending…';
  feedback.textContent = ''; feedback.className = 'form-feedback';
  try {
    const res = await fetch('/api/stripe/invoice', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        clientName: leadName,
        clientEmail: leadEmail,
        service: document.getElementById('inv-service').value,
        amount: parseFloat(document.getElementById('inv-amount').value),
        description: document.getElementById('inv-desc').value,
      }),
    });
    const json = await res.json();
    if (res.ok) {
      feedback.textContent = `Invoice sent ✓`;
      feedback.className = 'form-feedback success';
      setTimeout(() => location.reload(), 1500);
    } else {
      feedback.textContent = json.error ?? 'Something went wrong';
      feedback.className = 'form-feedback error';
    }
  } catch {
    feedback.textContent = 'Network error';
    feedback.className = 'form-feedback error';
  } finally {
    btn.disabled = false; btn.textContent = 'Send Invoice';
  }
});

// ── Proposal form ──
document.getElementById('proposal-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('.btn-send');
  const feedback = document.getElementById('proposal-feedback');
  btn.disabled = true; btn.textContent = 'Sending…';
  feedback.textContent = ''; feedback.className = 'form-feedback';
  const body = document.getElementById('prop-body').value;
  const html = body.split('\n').map(l => `<p>${l || '&nbsp;'}</p>`).join('');
  try {
    const res = await fetch('/api/email/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        to: leadEmail,
        subject: document.getElementById('prop-subject').value,
        html,
      }),
    });
    const json = await res.json();
    if (res.ok) {
      feedback.textContent = 'Proposal sent ✓';
      feedback.className = 'form-feedback success';
      // Auto-update stage to Proposal Sent
      await fetch(`/api/leads/${leadId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ stage: 'Proposal Sent' }),
      });
      setTimeout(() => location.reload(), 1500);
    } else {
      feedback.textContent = json.error ?? 'Something went wrong';
      feedback.className = 'form-feedback error';
    }
  } catch {
    feedback.textContent = 'Network error';
    feedback.className = 'form-feedback error';
  } finally {
    btn.disabled = false; btn.textContent = 'Send Proposal';
  }
});

// ── Follow-up form ──
document.getElementById('followup-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('.btn-send');
  const feedback = document.getElementById('followup-feedback');
  btn.disabled = true; btn.textContent = 'Sending…';
  feedback.textContent = ''; feedback.className = 'form-feedback';
  const body = document.getElementById('fu-body').value;
  const html = body.split('\n').map(l => `<p>${l || '&nbsp;'}</p>`).join('');
  try {
    const res = await fetch('/api/email/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        to: leadEmail,
        subject: document.getElementById('fu-subject').value,
        html,
      }),
    });
    const json = await res.json();
    if (res.ok) {
      feedback.textContent = 'Email sent ✓';
      feedback.className = 'form-feedback success';
      setTimeout(() => { document.getElementById('panel-followup').hidden = true; feedback.textContent = ''; }, 1500);
    } else {
      feedback.textContent = json.error ?? 'Something went wrong';
      feedback.className = 'form-feedback error';
    }
  } catch {
    feedback.textContent = 'Network error';
    feedback.className = 'form-feedback error';
  } finally {
    btn.disabled = false; btn.textContent = 'Send Email';
  }
});

// ── Stripe Customer ID save ──
document.getElementById('stripe-id-save').addEventListener('click', async () => {
  const input = document.getElementById('stripe-customer-id');
  const status = document.getElementById('stripe-id-status');
  status.textContent = 'Saving...';
  status.className = 'save-status saving';
  try {
    const res = await fetch(`/api/leads/${leadId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ stripeCustomerId: input.value }),
    });
    if (res.ok) {
      status.textContent = 'Saved ✓';
      status.className = 'save-status saved';
      setTimeout(() => { status.textContent = ''; }, 2000);
    } else {
      status.textContent = 'Error';
      status.className = 'save-status error';
    }
  } catch {
    status.textContent = 'Error';
    status.className = 'save-status error';
  }
});
</script>
