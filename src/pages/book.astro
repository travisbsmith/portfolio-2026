---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

---

<BaseLayout
  title="Book a Free Intro Call — Travis Smith | Shopify Expert"
  description="Book a free 30-minute intro call with Travis Smith. Former Head of Design at Shopify. Tell me about your store and let's see if working together makes sense."
>
  <Navigation />

  <main class="book">
    <div class="container container--narrow">

      <!-- Header -->
      <header class="book__header" id="book-header">
        <span class="label">Free Intro Call</span>
        <h1 class="book__title">Let's talk about your store</h1>
        <p class="book__subtitle">
          Tell me a bit about what you're building, then grab a time that works for you.
        </p>
        <div class="book__meta">
          <span class="book__meta-item">
            <span class="book__meta-icon">—</span>
            30 minutes
          </span>
          <span class="book__meta-item">
            <span class="book__meta-icon">—</span>
            Video call (Google Meet)
          </span>
          <span class="book__meta-item">
            <span class="book__meta-icon">—</span>
            Free, no commitment
          </span>
        </div>
      </header>

      <!-- Form -->
      <form
        id="booking-form"
        class="book__form"
        novalidate
      >
        <!-- Honeypot spam trap -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <!-- Section 1: About You -->
        <fieldset class="book__fieldset">
          <legend class="book__legend">About you</legend>

          <div class="book__row book__row--2col">
            <div class="book__field">
              <label class="book__label" for="name">Full name <span class="book__required">*</span></label>
              <input
                class="book__input"
                type="text"
                id="name"
                name="name"
                placeholder="Jane Doe"
                required
                autocomplete="name"
              />
            </div>
            <div class="book__field">
              <label class="book__label" for="email">Email address <span class="book__required">*</span></label>
              <input
                class="book__input"
                type="email"
                id="email"
                name="email"
                placeholder="jane@yourbrand.com"
                required
                autocomplete="email"
              />
            </div>
          </div>

          <div class="book__field">
            <label class="book__label" for="store_url">Shopify store URL</label>
            <input
              class="book__input"
              type="url"
              id="store_url"
              name="store_url"
              placeholder="https://yourstore.myshopify.com"
              autocomplete="url"
            />
            <span class="book__hint">Leave blank if you don't have a store yet.</span>
          </div>

          <div class="book__field">
            <label class="book__label">Store status <span class="book__required">*</span></label>
            <div class="book__radio-group">
              <label class="book__radio-label">
                <input type="radio" name="store_status" value="Not started yet" required />
                <span>Not started yet</span>
              </label>
              <label class="book__radio-label">
                <input type="radio" name="store_status" value="In progress, not live" />
                <span>Building it, not live yet</span>
              </label>
              <label class="book__radio-label">
                <input type="radio" name="store_status" value="Live and selling" />
                <span>Live and selling</span>
              </label>
            </div>
          </div>

          <div class="book__field" id="launch-date-field" style="display:none">
            <label class="book__label" for="launch_date">Target launch date</label>
            <input
              class="book__input book__input--sm"
              type="date"
              id="launch_date"
              name="launch_date"
            />
            <span class="book__hint">Helps me understand your timeline. No pressure if it's flexible.</span>
          </div>
        </fieldset>

        <!-- Section 2: What You Need -->
        <fieldset class="book__fieldset">
          <legend class="book__legend">What you need</legend>

          <div class="book__field">
            <label class="book__label" for="challenge">What's the #1 thing you want help with? <span class="book__required">*</span></label>
            <textarea
              class="book__input book__textarea"
              id="challenge"
              name="challenge"
              placeholder="e.g. I'm setting up my first store and don't know which theme to pick or which apps are actually worth it..."
              rows="4"
              required
            ></textarea>
          </div>

          <div class="book__field">
            <label class="book__label">Which service are you most interested in? <span class="book__required">*</span></label>
            <div class="book__radio-group book__radio-group--cards">

              <label class="book__service-card">
                <input type="radio" name="service_interest" value="Clarity Session ($500)" required />
                <div class="book__service-card-content">
                  <span class="book__service-card-name">Clarity Session</span>
                  <p class="book__service-card-desc">90-min audit + written action plan within 48 hrs</p>
                </div>
              </label>

              <label class="book__service-card">
                <input type="radio" name="service_interest" value="Insider Retainer ($3,500/mo)" />
                <div class="book__service-card-content">
                  <span class="book__service-card-name">Insider Retainer</span>
                  <p class="book__service-card-desc">Ongoing advisory — 2 calls/mo, async Slack, monthly audit</p>
                </div>
              </label>

              <label class="book__service-card">
                <input type="radio" name="service_interest" value="Store Launch Sprint ($2,500)" />
                <div class="book__service-card-content">
                  <span class="book__service-card-name">Store Launch Sprint</span>
                  <p class="book__service-card-desc">Zero to live in 2–3 weeks — theme, products, apps, roadmap</p>
                </div>
              </label>

              <label class="book__service-card">
                <input type="radio" name="service_interest" value="Not sure yet" />
                <div class="book__service-card-content">
                  <span class="book__service-card-name">Not sure yet</span>
                  <p class="book__service-card-desc">We'll figure out the right fit on the call</p>
                </div>
              </label>

            </div>
          </div>
        </fieldset>

        <!-- Section 3: Anything Else -->
        <fieldset class="book__fieldset">
          <legend class="book__legend">Anything else</legend>

          <div class="book__field">
            <label class="book__label" for="referral">How did you hear about me?</label>
            <input
              class="book__input"
              type="text"
              id="referral"
              name="referral"
              placeholder="e.g. My friend Sarah, LinkedIn, Google..."
            />
          </div>

          <div class="book__field">
            <label class="book__label">Do you work with a visual designer?</label>
            <div class="book__radio-group">
              <label class="book__radio-label">
                <input type="radio" name="has_visual_designer" value="Yes" />
                <span>Yes — I have a designer</span>
              </label>
              <label class="book__radio-label">
                <input type="radio" name="has_visual_designer" value="No" />
                <span>No — I handle design myself</span>
              </label>
              <label class="book__radio-label">
                <input type="radio" name="has_visual_designer" value="Looking" />
                <span>Not yet, but I'm looking</span>
              </label>
            </div>
          </div>

          <div class="book__field">
            <label class="book__label" for="notes">Anything else you want me to know before the call?</label>
            <textarea
              class="book__input book__textarea"
              id="notes"
              name="notes"
              placeholder="Optional — context, questions, whatever's on your mind."
              rows="3"
            ></textarea>
          </div>
        </fieldset>

        <!-- Submit -->
        <div class="book__submit">
          <button class="book__submit-btn" type="submit" id="submit-btn">
            Choose a time →
          </button>
          <p class="book__submit-note" id="submit-note">
            Pick a time that works for you on the next step.
          </p>
          <p class="book__error" id="submit-error" style="display:none"></p>
        </div>

      </form>

      <!-- Cal.com scheduling — shown after form submission -->
      <div id="cal-section" style="display:none">
        <div class="cal-header">
          <span class="cal-header__check" aria-hidden="true">✓</span>
          <div>
            <p class="cal-header__label">You're all set — one last step</p>
            <h2 class="cal-header__title">Pick a time for your call</h2>
            <p class="cal-header__sub">30 minutes · Google Meet · Free</p>
          </div>
        </div>
        <div class="cal-embed-wrapper">
          <div id="cal-inline"></div>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<!-- Cal.com embed script (deferred until after submit) -->
<script is:inline>
  // ── Launch date conditional ──
  const statusInputs = document.querySelectorAll('input[name="store_status"]');
  const launchDateField = document.getElementById('launch-date-field');
  function updateLaunchDateVisibility() {
    const selected = document.querySelector('input[name="store_status"]:checked')?.value ?? '';
    const prelaunch = selected === 'Not started yet' || selected === 'In progress, not live';
    if (launchDateField) launchDateField.style.display = prelaunch ? 'flex' : 'none';
  }
  statusInputs.forEach(i => i.addEventListener('change', updateLaunchDateVisibility));

  // ── Cal.com loader ──
  function loadCal(name, email) {
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal; let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {}; cal.q = cal.q || [];
          d.head.appendChild(d.createElement('script')).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const ns = ar[1];
          api.q = api.q || [];
          typeof ns === 'string' ? (cal.ns[ns] = api) && p(api, ar) : p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, 'https://app.cal.com/embed/embed.js', 'init');

    Cal('init', { origin: 'https://cal.com' });
    Cal('inline', {
      elementOrSelector: '#cal-inline',
      calLink: 'fullyoperational/intro-chat',
      config: {
        layout: 'month_view',
        name: name,
        email: email,
      },
    });
    Cal('ui', { hideEventTypeDetails: false, layout: 'month_view' });
  }

  // ── Form submission ──
  const form = document.getElementById('booking-form');
  const submitBtn = document.getElementById('submit-btn');
  const submitNote = document.getElementById('submit-note');
  const submitError = document.getElementById('submit-error');
  const calSection = document.getElementById('cal-section');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Basic validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving your details…';
    if (submitError) submitError.style.display = 'none';

    const name = document.getElementById('name').value;
    const email = document.getElementById('email').value;

    try {
      const res = await fetch('https://app.fully-operational.com/api/leads/new', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(form),
      });

      if (!res.ok) throw new Error('Server error');

      // Hide form, show Cal.com
      form.style.display = 'none';
      document.getElementById('book-header').style.display = 'none';
      calSection.style.display = 'block';
      loadCal(name, email);
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Choose a time →';
      if (submitError) {
        submitError.textContent = 'Something went wrong — please try again or email hello@fully-operational.com.';
        submitError.style.display = 'block';
      }
    }
  });
</script>

<style>
  .book {
    padding-top: calc(64px + var(--space-12));
    padding-bottom: var(--space-20);
  }

  /* ── Header ── */
  .book__header {
    margin-bottom: var(--space-12);
  }

  .book__header .label {
    display: block;
    margin-bottom: var(--space-4);
  }

  .book__title {
    font-size: clamp(1.75rem, 4vw, var(--text-4xl));
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }

  .book__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: var(--space-8);
  }

  .book__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .book__meta-item {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .book__meta-icon {
    color: var(--color-accent);
  }

  /* ── Form ── */
  .book__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .book__fieldset {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .book__legend {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    padding: 0;
    margin-bottom: var(--space-2);
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-4);
  }

  .book__row {
    display: flex;
    gap: var(--space-6);
  }

  .book__row--2col > * {
    flex: 1;
  }

  .book__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .book__label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
  }

  .book__required {
    color: var(--color-accent);
  }

  .book__hint {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: 1.5;
  }

  .book__input {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    width: 100%;
    transition: border-color var(--duration-fast) var(--ease);
    appearance: none;
    -webkit-appearance: none;
  }

  .book__input:focus {
    outline: none;
    border-color: var(--color-text);
  }

  .book__input::placeholder {
    color: var(--color-text-tertiary);
  }

  .book__textarea {
    resize: vertical;
    min-height: 100px;
    line-height: 1.6;
  }

  .book__input--sm {
    max-width: 240px;
  }

  .book__select {
    appearance: auto;
    -webkit-appearance: auto;
    cursor: pointer;
  }

  /* ── Radio group ── */
  .book__radio-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .book__radio-label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    cursor: pointer;
  }

  .book__radio-label input[type="radio"] {
    accent-color: var(--color-accent);
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    cursor: pointer;
  }

  /* ── Service cards ── */
  .book__radio-group--cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .book__service-card {
    cursor: pointer;
    display: block;
  }

  .book__service-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .book__service-card-content {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    transition: border-color var(--duration-fast) var(--ease), background var(--duration-fast) var(--ease);
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .book__service-card:hover .book__service-card-content {
    border-color: var(--color-border-strong);
  }

  .book__service-card input[type="radio"]:checked + .book__service-card-content {
    border-color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .book__service-card-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
  }

  .book__service-card-desc {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Submit ── */
  .book__submit {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .book__submit-btn {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-text);
    border: none;
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-10);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease), opacity var(--duration-fast) var(--ease);
  }

  .book__submit-btn:hover:not(:disabled) {
    background: var(--color-accent);
  }

  .book__submit-btn:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .book__submit-note {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: 1.5;
  }

  .book__error {
    font-size: var(--text-sm);
    color: #c0392b;
    line-height: 1.5;
  }

  /* ── Cal.com section ── */
  .cal-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-5);
    margin-bottom: var(--space-10);
  }

  .cal-header__check {
    display: inline-flex;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    font-size: var(--text-sm);
    font-weight: 600;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    margin-top: 4px;
  }

  .cal-header__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-2);
  }

  .cal-header__title {
    font-size: clamp(1.5rem, 3vw, var(--text-3xl));
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: var(--space-2);
  }

  .cal-header__sub {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .cal-embed-wrapper {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  #cal-inline {
    width: 100%;
    min-height: 600px;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .book__row--2col {
      flex-direction: column;
    }

    .book__radio-group--cards {
      grid-template-columns: 1fr;
    }

    .book__input--sm {
      max-width: 100%;
    }
  }
</style>
