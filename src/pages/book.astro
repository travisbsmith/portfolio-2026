---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

---

<BaseLayout
  title="Book a Free Intro Call — Travis Smith | Shopify Expert"
  description="Book a free 30-minute intro call with Travis Smith. Former Head of Design at Shopify. Tell me about your store and let's see if working together makes sense."
>
  <Navigation />

  <main class="book">
    <div class="container container--narrow">

      <!-- Header -->
      <header class="book__header">
        <span class="label">Free Intro Call</span>
        <h1 class="book__title">Let's talk about your store</h1>
        <p class="book__subtitle">
          Fill this out and I'll reply within one business day with a few time options. No pitch — just a real conversation about what you're building.
        </p>
        <div class="book__meta">
          <span class="book__meta-item">
            <span class="book__meta-icon">—</span>
            30 minutes
          </span>
          <span class="book__meta-item">
            <span class="book__meta-icon">—</span>
            Video call (Google Meet)
          </span>
          <span class="book__meta-item">
            <span class="book__meta-icon">—</span>
            Free, no commitment
          </span>
        </div>
      </header>

      <!-- Form -->
      <form
        id="booking-form"
        class="book__form"
        action="/api/leads/new"
        method="POST"
      >
        <!-- Honeypot spam trap -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <!-- Section 1: About You -->
        <fieldset class="book__fieldset">
          <legend class="book__legend">About you</legend>

          <div class="book__row book__row--2col">
            <div class="book__field">
              <label class="book__label" for="name">Full name <span class="book__required">*</span></label>
              <input
                class="book__input"
                type="text"
                id="name"
                name="name"
                placeholder="Jane Doe"
                required
                autocomplete="name"
              />
            </div>
            <div class="book__field">
              <label class="book__label" for="email">Email address <span class="book__required">*</span></label>
              <input
                class="book__input"
                type="email"
                id="email"
                name="email"
                placeholder="jane@yourbrand.com"
                required
                autocomplete="email"
              />
            </div>
          </div>

          <div class="book__field">
            <label class="book__label" for="store_url">Shopify store URL</label>
            <input
              class="book__input"
              type="url"
              id="store_url"
              name="store_url"
              placeholder="https://yourstore.myshopify.com"
              autocomplete="url"
            />
            <span class="book__hint">Leave blank if you don't have a store yet.</span>
          </div>

          <div class="book__field">
            <label class="book__label">Store status <span class="book__required">*</span></label>
            <div class="book__radio-group">
              <label class="book__radio-label">
                <input type="radio" name="store_status" value="Not started yet" required />
                <span>Not started yet</span>
              </label>
              <label class="book__radio-label">
                <input type="radio" name="store_status" value="In progress, not live" />
                <span>Building it, not live yet</span>
              </label>
              <label class="book__radio-label">
                <input type="radio" name="store_status" value="Live and selling" />
                <span>Live and selling</span>
              </label>
            </div>
          </div>
        </fieldset>

        <!-- Section 2: What You Need -->
        <fieldset class="book__fieldset">
          <legend class="book__legend">What you need</legend>

          <div class="book__field">
            <label class="book__label" for="challenge">What's the #1 thing you want help with? <span class="book__required">*</span></label>
            <textarea
              class="book__input book__textarea"
              id="challenge"
              name="challenge"
              placeholder="e.g. I'm setting up my first store and don't know which theme to pick or which apps are actually worth it..."
              rows="4"
              required
            ></textarea>
          </div>

          <div class="book__field">
            <label class="book__label">Which service are you most interested in? <span class="book__required">*</span></label>
            <div class="book__radio-group book__radio-group--cards">

              <label class="book__service-card">
                <input type="radio" name="service_interest" value="Clarity Session ($350)" required />
                <div class="book__service-card-content">
                  <span class="book__service-card-name">Clarity Session</span>
                  <p class="book__service-card-desc">90-min audit + written action plan within 48 hrs</p>
                </div>
              </label>

              <label class="book__service-card">
                <input type="radio" name="service_interest" value="Insider Retainer ($2,500/mo)" />
                <div class="book__service-card-content">
                  <span class="book__service-card-name">Insider Retainer</span>
                  <p class="book__service-card-desc">Ongoing advisory — 2 calls/mo, async Slack, monthly audit</p>
                </div>
              </label>

              <label class="book__service-card">
                <input type="radio" name="service_interest" value="Store Launch Sprint ($1,800)" />
                <div class="book__service-card-content">
                  <span class="book__service-card-name">Store Launch Sprint</span>
                  <p class="book__service-card-desc">Zero to live in 2–3 weeks — theme, products, apps, roadmap</p>
                </div>
              </label>

              <label class="book__service-card">
                <input type="radio" name="service_interest" value="Not sure yet" />
                <div class="book__service-card-content">
                  <span class="book__service-card-name">Not sure yet</span>
                  <p class="book__service-card-desc">We'll figure out the right fit on the call</p>
                </div>
              </label>

            </div>
          </div>
        </fieldset>

        <!-- Section 3: Availability -->
        <fieldset class="book__fieldset">
          <legend class="book__legend">Your availability</legend>
          <p class="book__fieldset-hint">All times are Central Time (CT). I'll reply with specific options that work for both of us.</p>

          <div class="book__field">
            <label class="book__label">Preferred days <span class="book__required">*</span></label>
            <div class="book__check-group">
              <label class="book__check-label">
                <input type="checkbox" name="available_days" value="Monday" />
                <span>Mon</span>
              </label>
              <label class="book__check-label">
                <input type="checkbox" name="available_days" value="Tuesday" />
                <span>Tue</span>
              </label>
              <label class="book__check-label">
                <input type="checkbox" name="available_days" value="Wednesday" />
                <span>Wed</span>
              </label>
              <label class="book__check-label">
                <input type="checkbox" name="available_days" value="Thursday" />
                <span>Thu</span>
              </label>
              <label class="book__check-label">
                <input type="checkbox" name="available_days" value="Friday" />
                <span>Fri</span>
              </label>
            </div>
          </div>

          <div class="book__field">
            <label class="book__label">Preferred time ranges (CT) <span class="book__required">*</span></label>
            <div class="book__check-group">
              <label class="book__check-label">
                <input type="checkbox" name="available_times" value="Morning (8–11am CT)" />
                <span>Morning 8–11am</span>
              </label>
              <label class="book__check-label">
                <input type="checkbox" name="available_times" value="Midday (11am–1pm CT)" />
                <span>Midday 11am–1pm</span>
              </label>
              <label class="book__check-label">
                <input type="checkbox" name="available_times" value="Afternoon (1–4pm CT)" />
                <span>Afternoon 1–4pm</span>
              </label>
              <label class="book__check-label">
                <input type="checkbox" name="available_times" value="Evening (4–6pm CT)" />
                <span>Evening 4–6pm</span>
              </label>
            </div>
          </div>

          <div class="book__field">
            <label class="book__label" for="timezone">Your timezone</label>
            <input
              class="book__input book__input--sm"
              type="text"
              id="timezone"
              name="timezone"
              placeholder="e.g. EST, PST, GMT+1"
            />
          </div>
        </fieldset>

        <!-- Section 4: Anything else -->
        <fieldset class="book__fieldset">
          <legend class="book__legend">Anything else</legend>

          <div class="book__field">
            <label class="book__label" for="referral">How did you hear about me?</label>
            <input
              class="book__input"
              type="text"
              id="referral"
              name="referral"
              placeholder="e.g. My friend Sarah, LinkedIn, Google..."
            />
          </div>

          <div class="book__field">
            <label class="book__label" for="notes">Anything else you want me to know before the call?</label>
            <textarea
              class="book__input book__textarea"
              id="notes"
              name="notes"
              placeholder="Optional — context, questions, whatever's on your mind."
              rows="3"
            ></textarea>
          </div>
        </fieldset>

        <!-- Submit -->
        <div class="book__submit">
          <button class="book__submit-btn" type="submit">
            Send request
          </button>
          <p class="book__submit-note">
            I'll reply within one business day with a few time options via email.
          </p>
        </div>

      </form>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .book {
    padding-top: calc(64px + var(--space-12));
    padding-bottom: var(--space-20);
  }

  /* ── Header ── */
  .book__header {
    margin-bottom: var(--space-12);
  }

  .book__header .label {
    display: block;
    margin-bottom: var(--space-4);
  }

  .book__title {
    font-size: clamp(1.75rem, 4vw, var(--text-4xl));
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }

  .book__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: var(--space-8);
  }

  .book__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .book__meta-item {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .book__meta-icon {
    color: var(--color-accent);
  }

  /* ── Form ── */
  .book__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .book__fieldset {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .book__legend {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    padding: 0;
    margin-bottom: var(--space-2);
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-4);
  }

  .book__fieldset-hint {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-top: calc(var(--space-2) * -1);
  }

  .book__row {
    display: flex;
    gap: var(--space-6);
  }

  .book__row--2col > * {
    flex: 1;
  }

  .book__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .book__label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
  }

  .book__required {
    color: var(--color-accent);
  }

  .book__hint {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: 1.5;
  }

  .book__input {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    width: 100%;
    transition: border-color var(--duration-fast) var(--ease);
    appearance: none;
    -webkit-appearance: none;
  }

  .book__input:focus {
    outline: none;
    border-color: var(--color-text);
  }

  .book__input::placeholder {
    color: var(--color-text-tertiary);
  }

  .book__textarea {
    resize: vertical;
    min-height: 100px;
    line-height: 1.6;
  }

  .book__input--sm {
    max-width: 240px;
  }

  /* ── Radio group (inline) ── */
  .book__radio-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .book__radio-label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    cursor: pointer;
  }

  .book__radio-label input[type="radio"] {
    accent-color: var(--color-accent);
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    cursor: pointer;
  }

  /* ── Service cards (radio) ── */
  .book__radio-group--cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .book__service-card {
    cursor: pointer;
    display: block;
  }

  .book__service-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .book__service-card-content {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    transition: border-color var(--duration-fast) var(--ease), background var(--duration-fast) var(--ease);
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .book__service-card:hover .book__service-card-content {
    border-color: var(--color-border-strong);
  }

  .book__service-card input[type="radio"]:checked + .book__service-card-content {
    border-color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .book__service-card-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
  }

  .book__service-card-desc {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Checkboxes ── */
  .book__check-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .book__check-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--duration-fast) var(--ease), background var(--duration-fast) var(--ease);
  }

  .book__check-label:hover {
    border-color: var(--color-border-strong);
  }

  .book__check-label input[type="checkbox"] {
    accent-color: var(--color-accent);
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    cursor: pointer;
  }

  .book__check-label:has(input:checked) {
    border-color: var(--color-text);
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  /* ── Submit ── */
  .book__submit {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .book__submit-btn {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-bg);
    background: var(--color-text);
    border: none;
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-10);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease), opacity var(--duration-fast) var(--ease);
  }

  .book__submit-btn:hover {
    background: var(--color-accent);
  }

  .book__submit-btn:active {
    opacity: 0.85;
  }

  .book__submit-note {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: 1.5;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .book__row--2col {
      flex-direction: column;
    }

    .book__radio-group--cards {
      grid-template-columns: 1fr;
    }

    .book__input--sm {
      max-width: 100%;
    }
  }
</style>
